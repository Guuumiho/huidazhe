{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Local QA Window",
  "version": "0.1.0",
  "identifier": "com.localqawindow.app",
  "build": {
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Local QA Window",
        "width": 1280,
        "height": 860,
        "resizable": true,
        "minWidth": 1000,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
